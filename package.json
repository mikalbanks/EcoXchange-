{
  "name": "ecoxchange",
  "version": "1.0.0",
  "private": true,
  "description": "EcoXchange – Digital Securities Platform for Tokenized Renewable Energy",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "vite build && tsc --project tsconfig.server.json",
    "start": "node dist/server/index.js",
