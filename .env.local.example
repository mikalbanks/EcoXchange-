############################################
# EcoXchange local environment (example)
############################################

# Supabase / DB / sessions
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
SESSION_SECRET=change-me

# NLR / NSRDB (NREL domain transition: developer.nlr.gov)
NREL_API_KEY=your_nlr_api_key_here
# NSRDB download endpoints require an email parameter
NREL_NSRDB_EMAIL=you@institution.com

# EIA Open Data API v2
EIA_API_KEY=your_eia_api_key_here

# AI Providers (multi-model router)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_api_key_here

# Institutional market reference (optional overrides; defaults align to LevelTen P25 Q1 2026 ~$64.49/MWh)
# CAISO_NP15_USD_PER_MWH=64.49
# CAISO_SP15_USD_PER_MWH=64.49
