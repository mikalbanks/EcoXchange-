# Cursor MCP environment variables (example)
# Copy to your local shell profile / secret manager (do not commit real values).

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_pat_here

# Supabase MCP (management API)
SUPABASE_ACCESS_TOKEN=sbp_your_supabase_personal_access_token_here
SUPABASE_PROJECT_REF=your_project_ref

# Postgres MCP (direct DB access)
# URI from Supabase -> Project Settings -> Database -> Connection string
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
